# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Source code
*.py text eol=lf diff=python
*.html text eol=lf diff=html
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf
Makefile text eol=lf

# Documentation
*.md text eol=lf diff=markdown
*.txt text eol=lf

# Binary — do not diff or merge
*.sqlite3 binary
